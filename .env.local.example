# Elastic Path Commerce Cloud
NEXT_PUBLIC_EPCC_ENDPOINT_URL=euwest.api.elasticpath.com
NEXT_PUBLIC_EPCC_CLIENT_ID=your-client-id
NEXT_PUBLIC_PASSWORD_PROFILE_ID=be403a4f-2b15-4ccb-b123-1201622cbd29

# Brand colors (hex without #)
NEXT_PUBLIC_BRAND_PRIMARY=#000000
NEXT_PUBLIC_BRAND_SECONDARY=#144e31
NEXT_PUBLIC_BRAND_ACCENT=#56dc9b

# Plasmic CMS — leave blank to disable Plasmic (falls back to hard-coded page sections)
NEXT_PUBLIC_PLASMIC_PROJECT_ID=project-id
NEXT_PUBLIC_PLASMIC_API_TOKEN=token

# Storefront password gate — set a value to require a password before accessing any page
# Leave empty or remove to disable
GATEKEEPER_PASSWORD=test

# Preferences for user
NEXT_PUBLIC_DEFAULT_CART_MODE=drawer
NEXT_PUBLIC_DEFAULT_SHOPPING_MODE=b2c

# Default view mode for the B2B cart page: "list" or "grid"
NEXT_PUBLIC_CART_VIEW_MODE=list
